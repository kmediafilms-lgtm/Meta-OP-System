{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Campaign",
  "description": "Campaña de Meta Ads con sus métricas",
  "type": "object",
  "required": ["id", "brand_id", "meta_campaign_id", "name", "objective", "status"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "brand_id": { "type": "string" },
    "meta_campaign_id": { "type": "string" },
    "name": { "type": "string" },
    "objective": { "type": "string", "enum": ["MESSAGES", "LEAD_GENERATION", "AWARENESS", "TRAFFIC", "CONVERSIONS", "ENGAGEMENT"] },
    "status": { "type": "string", "enum": ["ACTIVE", "PAUSED", "COMPLETED", "ARCHIVED"] },
    "budget": { "type": "number" },
    "budget_type": { "type": "string", "enum": ["daily", "lifetime"] },
    "spend": { "type": "number" },
    "impressions": { "type": "integer" },
    "reach": { "type": "integer" },
    "frequency": { "type": "number" },
    "ctr": { "type": "number" },
    "cpc": { "type": "number" },
    "cpm": { "type": "number" },
    "conversations_started": { "type": "integer" },
    "cost_per_conversation": { "type": "number" },
    "leads": { "type": "integer" },
    "qualified_leads": { "type": "integer" },
    "bookings": { "type": "integer" },
    "cost_per_lead": { "type": "number" },
    "cost_per_qualified_lead": { "type": "number" },
    "cost_per_booking": { "type": "number" },
    "period_start": { "type": "string", "format": "date" },
    "period_end": { "type": "string", "format": "date" },
    "winning_creative": { "type": ["string", "null"] },
    "weak_creative": { "type": ["string", "null"] },
    "top_intent_received": { "type": ["string", "null"] },
    "hypothesis": { "type": ["string", "null"] },
    "recommendation": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
