{
  "name": "intent-classifier",
  "version": "1.0.0",
  "purpose": "Clasificar la intención de un mensaje entrante con el tono correcto para la marca. Determinar si requiere humano. Nunca responde, solo clasifica.",
  "input_schema": {
    "type": "object",
    "required": [
      "brand_id",
      "message_text",
      "channel"
    ],
    "properties": {
      "brand_id": {
        "type": "string"
      },
      "message_text": {
        "type": "string"
      },
      "channel": {
        "type": "string"
      },
      "sender_history": {
        "type": "array",
        "description": "Mensajes anteriores del contacto"
      }
    }
  },
  "output_schema": {
    "type": "object",
    "required": [
      "intent",
      "confidence",
      "sentiment",
      "requires_human",
      "reason"
    ],
    "properties": {
      "intent": {
        "type": "string",
        "enum": [
          "precio",
          "disponibilidad",
          "paquetes_boda",
          "video_corporativo",
          "traslado",
          "quiere_portafolio",
          "pregunta_general",
          "cliente_caliente",
          "cliente_tibio",
          "cliente_frio",
          "reclamo",
          "descuento",
          "contrato_pago",
          "spam",
          "campaign_event",
          "tour_inquiry",
          "jardineria_inquiry",
          "unknown"
        ]
      },
      "confidence": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "sentiment": {
        "type": "string",
        "enum": [
          "positive",
          "neutral",
          "negative",
          "urgent"
        ]
      },
      "requires_human": {
        "type": "boolean"
      },
      "reason": {
        "type": "string"
      }
    }
  },
  "allowed_actions": [
    "classify_text",
    "read_brand_config",
    "log_classification"
  ],
  "blocked_actions": [
    "send_message",
    "modify_campaign",
    "call_meta_api",
    "write_to_crm",
    "browser_automation",
    "scraping",
    "campaign_mutation_without_approval",
    "budget_change_without_approval",
    "whatsapp_send_without_opt_in"
  ],
  "requires_human_rules": [
    "intent IN ['reclamo', 'descuento', 'contrato_pago']",
    "sentiment === 'urgent' AND intent === 'reclamo'",
    "confidence < 0.4",
    "brand_id === 'unidentified'"
  ],
  "failure_modes": [
    {
      "condition": "empty_message",
      "action": "return unknown intent, requires_human: false"
    },
    {
      "condition": "language_not_es",
      "action": "classify anyway, flag language in reason"
    }
  ],
  "description": "Clasificar la intención de un mensaje entrante con el tono correcto para la marca. Determinar si requiere humano. Nunca responde, solo clasifica.",
  "max_tokens": 1024
}